{
  "log": {
    "loglevel": "warning"
  },
  "inbounds": [
    {
      "port": 2101,
      "protocol": "socks",
      "settings": {
        "udp": true
      },
      "sniffing": {
        "enabled": true,
        "destOverride": [
          "http",
          "tls"
        ]
      }
    }
  ],
  "outbounds": [
    {
      "protocol": "vless",
      "settings": {
        "vnext": [
          {
            "address": "wstg.datasynctrue.online",
            "port": 443,
            "users": [
              {
                "id": "ff0b6ba8-bed0-4c4d-bbc9-23af47582615",
                "encryption": "none",
                "flow": ""
              }
            ]
          }
        ]
      },
      "streamSettings": {
        "network": "ws",
        "security": "tls",
        "tlsSettings": {
          "serverName": "wstg.datasynctrue.online",
          "allowInsecure": true
        },
        "wsSettings": {
          "path": "/api/connect",
          "headers": {
            "Host": "wstg.datasynctrue.online"
          }
        }
      }
    }
  ]
}