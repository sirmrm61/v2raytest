{
  "log": {
    "loglevel": "warning"
  },
  "inbounds": [
    {
      "port": 2133,
      "protocol": "socks",
      "settings": {
        "udp": true
      },
      "sniffing": {
        "enabled": true,
        "destOverride": [
          "http",
          "tls"
        ]
      }
    }
  ],
  "outbounds": [
    {
      "protocol": "vless",
      "settings": {
        "vnext": [
          {
            "address": "www.speedtest.net",
            "port": 443,
            "users": [
              {
                "id": "f7e3ff36-276c-4477-b6d4-47257500d869",
                "encryption": "none",
                "flow": ""
              }
            ]
          }
        ]
      },
      "streamSettings": {
        "network": "ws",
        "security": "tls",
        "tlsSettings": {
          "serverName": "pon.antalmani.mm.am",
          "allowInsecure": true
        },
        "wsSettings": {
          "path": "/?ed=3000",
          "headers": {
            "Host": "pon.antalmani.mm.am"
          }
        }
      }
    }
  ]
}