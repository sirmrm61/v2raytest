{
  "log": {
    "loglevel": "warning"
  },
  "inbounds": [
    {
      "port": 2096,
      "protocol": "socks",
      "settings": {
        "udp": true
      },
      "sniffing": {
        "enabled": true,
        "destOverride": [
          "http",
          "tls"
        ]
      }
    }
  ],
  "outbounds": [
    {
      "protocol": "vless",
      "settings": {
        "vnext": [
          {
            "address": "email protected",
            "port": 8880,
            "users": [
              {
                "id": null,
                "encryption": "none",
                "flow": ""
              }
            ]
          }
        ]
      },
      "streamSettings": {
        "network": "grpc",
        "security": "tls",
        "tlsSettings": {
          "serverName": "free.ziroxcompany.ir",
          "allowInsecure": true
        },
        "grpcSettings": {
          "serviceName": "/dashboard",
          "multiMode": false
        }
      }
    }
  ]
}