{
  "log": {
    "loglevel": "warning"
  },
  "inbounds": [
    {
      "port": 2099,
      "protocol": "socks",
      "settings": {
        "udp": true
      },
      "sniffing": {
        "enabled": true,
        "destOverride": [
          "http",
          "tls"
        ]
      }
    }
  ],
  "outbounds": [
    {
      "protocol": "trojan",
      "settings": {
        "servers": [
          {
            "address": "172.64.35.169",
            "port": 443,
            "users": [
              {
                "password": "auto"
              }
            ]
          }
        ]
      },
      "streamSettings": {
        "network": "ws",
        "security": "tls",
        "tlsSettings": {
          "serverName": "trojanmz.pages.dev",
          "allowInsecure": true
        },
        "wsSettings": {
          "path": "/trojanmz.pages.dev/?ed=2560",
          "headers": {
            "Host": "trojanmz.pages.dev"
          }
        }
      }
    }
  ]
}