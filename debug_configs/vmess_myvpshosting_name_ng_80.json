{
  "log": {
    "loglevel": "warning"
  },
  "inbounds": [
    {
      "port": 2176,
      "protocol": "socks",
      "settings": {
        "udp": true
      },
      "sniffing": {
        "enabled": true,
        "destOverride": [
          "http",
          "tls"
        ]
      }
    }
  ],
  "outbounds": [
    {
      "protocol": "vmess",
      "settings": {
        "vnext": [
          {
            "address": "myvpshosting.name.ng",
            "port": 80,
            "users": [
              {
                "id": "96408f9a-df03-448b-b7e4-ec8e2c216682",
                "alterId": 0,
                "security": "auto"
              }
            ]
          }
        ]
      },
      "streamSettings": {
        "network": "ws",
        "wsSettings": {
          "path": "/vmess",
          "headers": {
            "Host": "myvpshosting.name.ng"
          }
        }
      }
    }
  ]
}